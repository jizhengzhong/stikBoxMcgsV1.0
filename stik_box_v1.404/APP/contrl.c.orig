void Temp_Hea_State( u8 state)
{
	state == Heat_OFF  ? HEAT_OFF: HEAT_ON;

}

void HeatControl(PID_Para *PID_Parameter,InterParaTwo *ParaCtrl,
								 Para_Flag_STRUCT *Para_Flag_Structment)
{  
    s32 temp1,temp2;
    s16 temp_a;
    s32 temp_b;
    if(Para_Flag_Structment->Flag_Over||Para_Flag_Structment->Flag_Protect) //温度溢出标志，ji
                                                                   //温度保护标志，1:停止加热 0:允许加热ji
    {
        PID_Parameter->DFVaule=PID_Parameter->Measure; //微分先行后微分值
        PID_Parameter->LastMeasure=PID_Parameter->Measure;//上一次温度测量值
        return;
    }
    if(!CONTROL.Flag_EnRun)         //控制器运行停止标志位
    {

    }
    else
    {
        CONTROL.Flag_Cool = 0;
    }
    if(CONTROL.Flag_TempRun)  ////控制器停止温度控制标志位
    {
        if(Temp_Ctrl.nod == 2)//程序控制模式
        {
//            TIME.Flag_EnTime=0;  //允许计时标志位 
//            TIME.Flag_TimeEnd=0; //计时结束标志位 
            if(SP_Buffer[CONTROL.Ctrl_Step]>=SP_Buffer[CONTROL.Ctrl_Step-1])//升温
                CONTROL.Flag_TempDown = 0;  //控制器降温标志
            else CONTROL.Flag_TempDown = 1;       
            if(ST_Buffer[CONTROL.Ctrl_Step] == 0)// ST=0:正常PID控制达到目标温度
            {
                if(Time_runmin >9999)Time_runmin=9999;
                      PID_Parameter->Target = SP_Buffer[CONTROL.Ctrl_Step];
                if(CONTROL.Flag_TempDown==0)//升温
                {
                    if(Temp_Display >= PID_Parameter->Target )//达到目标，值进入下一步控制
                    {
                        CONTROL.Ctrl_Step++;
                        Time_runsec = 0;//编程模式运行时间秒
                        Time_runmin = 0;//编程模式运行时间分
                    }
                }
                else//降温
                {
                    if(Temp_Display <= PID_Parameter->Target )//达到目标，值进入下一步控制
                    {
                        CONTROL.Ctrl_Step++;
                        Time_runsec = 0;//编程模式运行时间秒
                        Time_runmin = 0;//编程模式运行时间分
                    }
                }
            }
            else if(ST_Buffer[CONTROL.Ctrl_Step] == -1)//ST=-1:以上一段温度继续运行
            {
                if(Time_runmin >9999)Time_runmin=9999;
                    PID_Parameter->Target  = SP_Buffer[CONTROL.Ctrl_Step-1];
            }
            else if(ST_Buffer[CONTROL.Ctrl_Step] == -2)//ST=-2:运行到此段结束
            {
                CONTROL.Flag_EnRun = 0;
                CONTROL.Flag_TempRun = 0;
                CONTROL.Code_End = 1;
                CONTROL.Ctrl_Step = 1;
            }
            else if(ST_Buffer[CONTROL.Ctrl_Step] > 0) //ST>0:表示该段温控时间
            {
                if(Temp_Ctrl.Cnd == 1)//温度到达目标值，进入下一段控制
                {
                    if(Time_runmin >9999)Time_runmin=9999;
                    if(SP_Buffer[CONTROL.Ctrl_Step]>=SP_Buffer[CONTROL.Ctrl_Step-1])//升温
                    {
                        if(Temp_Display >= SP_Buffer[CONTROL.Ctrl_Step])//达到目标，值进入下一步控制 
                        {
                            CONTROL.Ctrl_Step++;
                            Time_runsec = 0;//编程模式运行时间秒
                            Time_runmin = 0;//编程模式运行时间分
                        }
                    }
                    else//降温
                    {
                        if(Temp_Display <= SP_Buffer[CONTROL.Ctrl_Step])//达到目标，值进入下一步控制 
                        {
                            CONTROL.Ctrl_Step++;
                            Time_runsec = 0;//编程模式运行时间秒
                            Time_runmin = 0;//编程模式运行时间分
                        }
                    }  
                }
                if(Time_runmin >= ST_Buffer[CONTROL.Ctrl_Step])//运行时间到
                {   
                    if(Temp_Ctrl.Cnd == 0)//时间到达目标值，进入下一段控制
                    {
                        PID_Parameter->Target  = SP_Buffer[CONTROL.Ctrl_Step];//目标温度
                        CONTROL.Ctrl_Step++;
                        Time_runsec = 0;//编程模式运行时间秒
                        Time_runmin = 0;//编程模式运行时间分
                    }   
                    else
                        PID_Parameter->Target  = SP_Buffer[CONTROL.Ctrl_Step];//目标温度
                }
                else//运行时间未到
                {
                    if(ST_Buffer[CONTROL.Ctrl_Step]>2000)//分钟计时
                    {
                        temp1=(s32)(SP_Buffer[CONTROL.Ctrl_Step]-SP_Buffer[CONTROL.Ctrl_Step-1])*Time_runmin;
                        temp1=temp1/ST_Buffer[CONTROL.Ctrl_Step];
                        PID_Parameter->Target =SP_Buffer[CONTROL.Ctrl_Step-1]+temp1;	
                    }
                    else//换算成秒
                    { 
                        temp2=(s32)ST_Buffer[CONTROL.Ctrl_Step]*60; //换算成秒
                        if (temp2>=Time_runsec)//运行时间未到
                        {
                            temp1=(s32)(SP_Buffer[CONTROL.Ctrl_Step]-SP_Buffer[CONTROL.Ctrl_Step-1])*Time_runsec;
                            temp1=temp1/temp2;
                            PID_Parameter->Target =SP_Buffer[CONTROL.Ctrl_Step-1]+temp1;
                        } 
                    }
                }         
            }
        }
        else//非编程模式下
        {   
            if(Temp_Display <= PID_Parameter->Target )
                CONTROL.Flag_TempDown=0;  //控制器降温标志
            if(CONTROL.Flag_EnRun==0)
            {
                Time_5min=0;
                PID_Parameter->Flag_DisIsum = 0;//禁止积分
            }
//            PID_Parameter->Target  = Temp_Set;//目标温度
            Time_runsec = 0;//编程模式运行时间秒
            Time_runmin = 0;//编程模式运行时间分
        }   
    }
    //禁止积分处理
    if(Time_5min>180) 
    {
        Time_5min =400;
        PID_Parameter->Flag_DisIsum = 1;  //禁止加热积分累积  
    }
    //溢出、定时结束后停止温控、禁止温度控制时关断加热  //自整定标志位
    if(Para_Flag_Structment->Flag_Over||((CONTROL.Flag_TempRun==0)))//温度溢出或停止温控
    { 
			  PID_Parameter->HeatCallback(Heat_OFF);
        Para_Flag_Structment->Flag_HeatOut=0;
        
        //PID控制赋初值
        Temp_SetDiff = 0;
        Time_5min=0;//禁止积分计时清零
        PID_Parameter->Flag_DisIsum=0; 
	      PID_Parameter->ISumVaule=0;    
        PID_Parameter->DFVaule=PID_Parameter->Measure; 
        PID_Parameter->LastMeasure=PID_Parameter->Measure; 
        
	      return;	
    }

    
        if(PID_Parameter->Time_HeatCycle >= PID_Parameter->T)//加热一个周期   ParaTempPID.T = 5;   //控制周期
        {
						PID_Parameter->Time_HeatCycle=0;   //Time_HeatCycle  加热控制周期计时
						PID_Parameter->Time_HeatCounter=0;	//Time_HeatCounter 加热控制时间计时

            //输出功率控制
             PID_Calculate( PID_Parameter,ParaCtrl);
            if(Temp_SetDiff>=5||Temp_SetDiff<=-5)
								{
									Time_5min=0;
								  PID_Parameter->Flag_DisIsum=0;
								  Temp_SetDiff=0;
								}//设定值变化超5，禁止积分 
								
            temp_a=PID_Parameter->OutValue*PID_Parameter->T;//PID输出值*控制周期
            temp_b=temp_a*PID_Parameter->AR*0.01;//乘积*功率
            PID_Parameter->OutValue=(s16)temp_b;
        }   
        else
        { 
							if(Para_Flag_Structment->Flag_Alm) 
										{
											 PID_Parameter-> HeatCallback(Heat_OFF);
												Para_Flag_Structment->Flag_HeatOut=0;
										} 
									else
									{
											if( PID_Parameter->Time_HeatCounter < PID_Parameter->OutValue )
														{

															  PID_Parameter->	HeatCallback(Heat_ON);
																Para_Flag_Structment->Flag_HeatOut=1;
														}
											else 
														{
															 PID_Parameter-> HeatCallback(Heat_OFF);
																Para_Flag_Structment->Flag_HeatOut=0;
														}
								  }
        }	

}

void Para_PID_Update(void)
{
  Temperature.P = ParTab[PAR_POS_P_SET ].uVal;
	Temperature.I = ParTab[PAR_POS_I_SET ].uVal;
	Temperature.d = ParTab[PAR_POS_D_SET ].uVal;
	Temperature.AR = ParTab[PAR_POS_AR_SET ].uVal;
	Temperature.T = ParTab[PAR_POS_T_SET ].uVal;
}

void Fan_Ctrl(void)
{
			RunFlow.FanOutMs    < ParUnSaved[PAR_POS_FAN_AR ].uVal ? Fan_OFF: Fan_ON ;
		if(ParTab[PAR_POS_Run_Stop_Command].uVal == 1)
		{
			if(Temperature.Measure < ParTab[PAR_POS_UNLOCK_TEMP ].uVal && RunFlow.StateParameter.KeepWarmPoint != 1)
				Lock_PowerOFF;
		}
		else
			{ 
				if( RunFlow.Err.ErrorFlag == 0)
				Temperature.Measure > ParTab[PAR_POS_UNLOCK_TEMP ].uVal ? Lock_PowerOFF:Lock_PowerON;
			}
}


 void CtrlTask(void *argument)
{
  /* USER CODE BEGIN CtrlTask */

  /* Infinite loop */
  for(;;)
  {
	if (ParTab[PAR_POS_WATER_F0_SWITCH].uVal == 1)
    F0_Calculation();
		Fan_Ctrl();
    osDelay(1);
  }
  /* USER CODE END CtrlTask */
}
