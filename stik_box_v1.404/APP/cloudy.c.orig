//查表法计算crc
///////////////modbus crc-16///////////////////////////
unsigned short  do_crc_table(unsigned char *ptr, int len)
{
    unsigned short crc = 0xFFFF;

    while (len--) {
        crc = (crc >> 8) ^ crc_table[(crc ^ *ptr++) & 0xff];
    }

    return (crc);
}


static void ReceiveProcess(void)
{
    BigLittleEnd ModbusCrc;

    /*-----------------------------------------------------------------------------------------*/
    /*                             处 理 串 口 1 接 收 到 的 数 据                             */
    /*-----------------------------------------------------------------------------------------*/
    if (U1_Control.URxDataOutPtr !=
            U1_Control.URxDataInPtr) {                                           //如果串口1的 URxDataOutPtr指针 和 URxDataInPtr指针不相等，则if成立，说明串口1有数据接收到了
        U1_Control.U_Rxdatalen = U1_Control.URxDataOutPtr->EndPtr -
                                 U1_Control.URxDataOutPtr->StartPtr;  //计算本次接收的数据量
        //			u1_printf("本次接收到 %d 字节数据\r\n",U1_Control.U_Rxdatalen);		                             //串口输出提示信息
        memset(U1Copy_RxBuff, 0, U1_COPYBUFF_SIZE);                                                      //清空缓冲区
        memcpy(U1Copy_RxBuff, U1_Control.URxDataOutPtr->StartPtr, U1_Control.U_Rxdatalen);               //提取数据
        ModbusCrc.value =	do_crc_table(&U1Copy_RxBuff[0], sizeof(U1Copy_RxBuff) -2);

        if (ModbusCrc.uBytes[0] == U1Copy_RxBuff[U1_COPYBUFF_SIZE - 1]
                && ModbusCrc.uBytes[1] == U1Copy_RxBuff[U1_COPYBUFF_SIZE - 2]) {
            Offline = 0;
            ParaUpdataCheck();
        }

        //			u1_printf("接收到的数据如下：\r\n%s\r\n\r\n",U1Copy_RxBuff);                                     //串口输出提示信息
        U1_Control.URxDataOutPtr++;    //串口1的 URxDataOutPtr指针 下移

        if (U1_Control.URxDataOutPtr ==
                U1_Control.URxDataEndPtr) {                                      //如果到达处理接收数据的结构体数组尾部了
            U1_Control.URxDataOutPtr = &U1_Control.UCB_RxBuffPtrCB[0];
        }
    } else {
        if (Offline++ < 500 && Offline % 2) {
            ParaUpdataCheck();
        } else if (Offline < 600) {
            HAL_UART_Transmit_DMA(&U1_Control.UART_Handler, (const uint8_t*)"AT+ENTM\r\n", sizeof("AT+ENTM\r\n"));
            Offline = 0;
        }
    }
}

void CloudyUpdata(uint16_t *pSend)
{
    uint8_t *pReceive = NULL;
    uint8_t *pSendStart = NULL;
    uint16_t Length, SendLength;
    pReceive = &U1Copy_RxBuff[0];
    uint8_t *pSendBuf = NULL;
    BigLittleEnd *pBigVale = (BigLittleEnd *) pSend;
    BigLittleEnd Crc;
    Length  = pReceive[4];
    Length = Length << 8 | pReceive[5];
    Length = Length << 1;
    SendLength = Length;
    pSendBuf = (uint8_t *) pvPortMalloc((Length + 5) * sizeof(uint8_t));

    if (pSendBuf != NULL) {
        pSendStart = pSendBuf;
        *pSendBuf++ = 0x01;
        *pSendBuf++ = 0x03;
        *pSendBuf++ = Length;

        while (Length > 0) {
            *pSendBuf++ = pBigVale->uBytes[1];
            Length--;
            *pSendBuf++ = pBigVale->uBytes[0];
            Length--;
            pBigVale++;
        }

        Crc.value = do_crc_table(pSendStart, SendLength + 3);
        *pSendBuf++ = Crc.uBytes[0];
        *pSendBuf++ = Crc.uBytes[1];
        HAL_UART_Transmit_DMA(&U1_Control.UART_Handler, (const uint8_t *)pSendStart, SendLength + 5);
        vPortFree(pSendStart);
        pSendStart = NULL;
        pSendBuf = NULL;
    }
}



uint8_t ParaUpdataCheck(void)
{
    uint8_t Lenth, SendLenth;
    uint8_t *pSendBuf = NULL;
    uint8_t *pSendStart = NULL;
    uint16_t Value[NEnd];
    BigLittleEnd *pBigVale = NULL;
    BigLittleEnd Crc;
    Value[NMeasure] = (uint16_t)(Temperature.Measure * 10);
    Value[NCount] = RunFlow.SteriCount;
    Value[NWater] = (uint16_t)(RunFlow.DisplayWater * 10);
    Value[NPressur] = (uint16_t)RunFlow.Pressure;
    Value[NSetTemp] = (uint16_t)Procedure.steri;
    Value[NSetTime] = Procedure.steri_time;

    if (Procedure.type == Liquid || Procedure.type == Melt) {
        Value[NSetKeepWarm] = Procedure.mode.keepwarm;
        Value[NKeepWarmTime] = Procedure.dry_kwarm_time.keepwarm;
    }else
		{
		        Value[NSetKeepWarm] = 0;
        Value[NKeepWarmTime] = 0;
		}

    RunFlow.flow_state == WORK_PROGRAM_FLOW_STATE_STERI  ?                     \
    (Value[NLeftTime] = Procedure.steri_time - RunFlow.SteriMinute) : (Value[NLeftTime] = 0);
    Value[NHeatState] = TEMP.Flag_HeatOut  ;
    Value[NError] =   RunFlow.Err.ErrorFlag ;
    RunFlow.flow_state == WORK_PROGRAM_FLOW_STATE_FINISH1  ?
    (Value[NDeviceState] = 1) : (Value[NDeviceState] = 0);
    Lenth = sizeof(Value);
    SendLenth = Lenth;
    pSendBuf = (uint8_t *) pvPortMalloc((Lenth + 10) * sizeof(uint8_t));
    pSendStart = pSendBuf;
    pBigVale = (BigLittleEnd *) &Value[0];

    if (pSendBuf != NULL) {
        *pSendBuf++ = 0x01;   // 从机地址
        *pSendBuf++ = 0x46;   // 写指令
        *pSendBuf++ = 0x00;   //起始地址
        *pSendBuf++ = 0x00;   //起始地址
        *pSendBuf++ = 0x00;   //寄存器单元长度
        *pSendBuf++ = Lenth >> 1; //寄存器单元长度
        *pSendBuf++ = Lenth;   //数据长度

        while (Lenth > 0) {
            *pSendBuf++ = pBigVale->uBytes[1];
            Lenth--;
            *pSendBuf++ = pBigVale->uBytes[0];
            Lenth--;
            pBigVale++;
        }

        Crc.value = do_crc_table(pSendStart, SendLenth + 7);
        *pSendBuf++ = Crc.uBytes[0];
        *pSendBuf++ = Crc.uBytes[1];
        HAL_UART_Transmit_DMA(&U1_Control.UART_Handler, (const uint8_t *)pSendStart, SendLenth + 9);
        vPortFree(pSendStart);
        pSendStart = NULL;
        pSendBuf = NULL;
    }
}




void CloudyTask(void *argument)
{
    /* USER CODE BEGIN CloudyTask */
    osDelay(100);
    ParaUpdataCheck();
    unsigned portBASE_TYPE uxHighWaterMark;

    /* Infinite loop */
    for (;;) {
        uxHighWaterMark = uxTaskGetStackHighWaterMark(NULL);
        ReceiveProcess();

        if (Offline > 500) {
            DR154Init((const uint8_t *)&U1Copy_RxBuff[0]);
        }

        osDelay(500);
    }

    /* USER CODE END CloudyTask */
}

void DR154Init(const uint8_t *pBuff)
{
    static uint8_t InitStep = 0;

    switch (InitStep) {
    case 0:
        HAL_UART_Transmit_DMA(&U1_Control.UART_Handler, (const uint8_t*)"+++", 3);
        InitStep = 1;
        break;

    case 1:
        if (pBuff[0] == 'a') {
            InitStep = 2;
        }

        break;

    case 2:
        HAL_UART_Transmit_DMA(&U1_Control.UART_Handler, (const uint8_t*)"a", 1);
        InitStep = 3;
        break;

    case 3:
        if (pBuff[0] == '+' && pBuff[1] == 'o' && pBuff[2] == 'k') {
            InitStep = 4;
        }

        break;

    case 4:
        HAL_UART_Transmit_DMA(&U1_Control.UART_Handler, (const uint8_t*)"AT+Z\r\n", sizeof("AT+Z\r\n"));
        InitStep = 5;
        break;

    case 5:
        if (pBuff[2] == 'O' && pBuff[3] == 'K') {
            InitStep = 6;
        }

        break;

    case 6:
        HAL_UART_Transmit_DMA(&U1_Control.UART_Handler, (const uint8_t*)"AT+ENTM\r\n", sizeof("AT+ENTM\r\n"));
        InitStep = 7;
        break;

    case 7:
        if (strstr((const char *)pBuff, "USR") != 0 || strstr((const char *)pBuff, "OK") != 0) {
            InitStep = 0;
            Offline = 0;
        }

        break;

    default :
        break;
    }
}


